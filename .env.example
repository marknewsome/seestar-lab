# Copy this file to .env and adjust the path.
# SEESTAR_DATA_DIR must point to the root folder that contains your
# Seestar S50 output (Stars/, Videos/, Photos/ sub-folders or equivalents).

SEESTAR_DATA_DIR=/mnt/d/xfer

# Observer location — used for aircraft bounding-box query
OBSERVER_LAT=44.5646
OBSERVER_LON=-123.2620

# OpenSky Network credentials (free account: https://opensky-network.org)
# Required to query historical state vectors (up to 30 days old).
OPENSKY_USERNAME=your_opensky_username
OPENSKY_PASSWORD=your_opensky_password
